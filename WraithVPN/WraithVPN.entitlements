<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  WraithVPN.entitlements

  Required entitlements for the main app target.

  IMPORTANT — these must be configured identically in:
    1. This file (Xcode signs against it during development)
    2. The App ID in the Apple Developer portal (for distribution)
    3. The provisioning profile

  Additional entitlements are required for the Network Extension target
  (see WireGuardTunnel/WireGuardTunnel.entitlements).
-->
<plist version="1.0">
<dict>
    <!-- ===== NetworkExtension ===== -->
    <!--
      Allows the app to create and manage VPN configurations.
      Value must match the sub-entitlement requested — packet-tunnel-provider
      is needed because WireGuard runs as a Packet Tunnel provider.
    -->
    <key>com.apple.developer.networking.networkextension</key>
    <array>
        <string>packet-tunnel-provider</string>
        <string>app-proxy-provider</string>
        <string>content-filter-provider</string>
        <string>dns-proxy</string>
    </array>

    <!-- ===== In-App Purchase ===== -->
    <key>com.apple.developer.in-app-payments</key>
    <array>
        <string>com.katafract.wraith_armor_monthly</string>
        <string>com.katafract.wraith_armor_annual</string>
    </array>

    <!-- ===== Keychain sharing ===== -->
    <!--
      Sharing the keychain group with the tunnel extension lets both
      processes access the WireGuard private key stored by the main app.
    -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.katafract.wraith</string>
        <string>$(AppIdentifierPrefix)com.katafract.wraith.tunnel</string>
    </array>

    <!-- ===== App Groups ===== -->
    <!--
      App groups let the main app and the tunnel extension share UserDefaults
      and a shared container for passing configuration at tunnel startup.
    -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.katafract.wraith</string>
    </array>
</dict>
</plist>
