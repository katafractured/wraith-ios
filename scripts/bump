#!/usr/bin/env bash
# bump — tag a new WraithVPN release and push to trigger Xcode Cloud
#
# Usage:
#   ./scripts/bump            # auto-increments patch (v1.0.59 → v1.0.60)
#   ./scripts/bump minor      # increments minor (v1.0.59 → v1.1.0)
#   ./scripts/bump major      # increments major (v1.0.59 → v2.0.0)
#   ./scripts/bump 1.2.3      # sets explicit version
#
# What it does:
#   1. Reads the latest v* tag from git
#   2. Computes the next version
#   3. Commits any staged or unstaged changes with a version bump message
#   4. Tags HEAD with vX.Y.Z
#   5. Pushes commit + tag → triggers Xcode Cloud Default workflow
#      → archives iOS build → uploads to TestFlight
#      → internal testers get it automatically (hasAccessToAllBuilds=true)

set -euo pipefail

# ── Find current version ────────────────────────────────────────────────────
CURRENT=$(git tag --list 'v*' --sort=-version:refname | head -1)
if [[ -z "$CURRENT" ]]; then
  echo "No v* tags found. Set an explicit version: ./scripts/bump 1.0.0"
  exit 1
fi

# Strip leading v
CURRENT_VER="${CURRENT#v}"
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VER"

# ── Compute next version ────────────────────────────────────────────────────
ARG="${1:-patch}"
case "$ARG" in
  major)
    NEXT="$((MAJOR + 1)).0.0" ;;
  minor)
    NEXT="${MAJOR}.$((MINOR + 1)).0" ;;
  patch)
    NEXT="${MAJOR}.${MINOR}.$((PATCH + 1))" ;;
  [0-9]*.[0-9]*.[0-9]*)
    NEXT="$ARG" ;;
  *)
    echo "Usage: bump [major|minor|patch|X.Y.Z]"
    exit 1 ;;
esac

TAG="v${NEXT}"

# ── Confirm ─────────────────────────────────────────────────────────────────
echo "  current : $CURRENT"
echo "  next    : $TAG"
echo ""
read -r -p "Tag and push $TAG? [y/N] " CONFIRM
if [[ "$(echo "$CONFIRM" | tr '[:upper:]' '[:lower:]')" != "y" ]]; then
  echo "Aborted."
  exit 0
fi

# ── Update version + build number in Xcode project ──────────────────────────
PBXPROJ="WraithVPN.xcodeproj/project.pbxproj"

# MARKETING_VERSION → git tag version (e.g. 1.0.73)
sed -i '' "s/MARKETING_VERSION = [0-9][0-9.]*;/MARKETING_VERSION = ${NEXT};/g" "$PBXPROJ"

# CURRENT_PROJECT_VERSION → increment by 1 (build number for TestFlight)
CURRENT_BUILD=$(grep -m1 'CURRENT_PROJECT_VERSION = ' "$PBXPROJ" | grep -oE '[0-9]+')
NEXT_BUILD=$(( CURRENT_BUILD + 1 ))
sed -i '' "s/CURRENT_PROJECT_VERSION = ${CURRENT_BUILD};/CURRENT_PROJECT_VERSION = ${NEXT_BUILD};/g" "$PBXPROJ"

echo "  version : ${NEXT} (build ${NEXT_BUILD})"

# ── Commit all pending changes (code + project version bump) ─────────────────
git add -A
git commit -m "Bump to $TAG"

# ── Tag and push ─────────────────────────────────────────────────────────────
# Push main first (separate from the tag so Xcode Cloud doesn't fire twice).
# Only the tag push triggers a build — remove the branch trigger in Xcode Cloud
# UI (Product → Xcode Cloud → Manage Workflows → Default → Start Conditions)
# to prevent the branch push from also starting a build.
git tag "$TAG"
git push origin main
git push origin "$TAG"

echo ""
echo "✓ Tagged $TAG and pushed."
echo "  Xcode Cloud will build and upload to TestFlight."
echo "  Internal testers will receive the build automatically."
echo ""
echo "  Monitor: ./check-builds"
